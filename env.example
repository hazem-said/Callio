# ─────────────────────────────────────────────
#  Callio – AI Restaurant Receptionist SaaS
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# SQLite (default for local dev):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/callio?schema=public"

# ── NextAuth ──────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-32-char-key-here"

# ── OpenAI ────────────────────────────────────
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── Twilio ────────────────────────────────────
# Get yours at https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Callio"

# ── Stripe (optional – billing) ───────────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
